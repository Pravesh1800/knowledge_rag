# Choose the active LLM provider: openrouter or openai
LLM_PROVIDER=openrouter

# Optional generic key used by the active provider.
# You can also use OPENROUTER_API_KEY or OPENAI_API_KEY below.
LLM_API_KEY=your_active_provider_key_here

# Active model aliases used by the app.
# If left blank in .env, the provider-specific model names below are used.
LLM_MODEL=google/gemini-3.1-flash-lite
LLM_MAP_MODEL=deepseek/deepseek-v4-flash
LLM_SEARCH_MODEL=deepseek/deepseek-v4-flash

# OpenRouter settings
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_MAP_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_SEARCH_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=Evidence Mesh
OPENROUTER_TIMEOUT_SECONDS=120
OPENROUTER_MAX_RETRIES=1
OPENROUTER_PAGE_RETRIES=3
OPENROUTER_RELATIONSHIP_WORKERS=12

# OpenAI settings
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAP_MODEL=gpt-4.1-mini
OPENAI_SEARCH_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Hybrid retrieval embeddings
# Build with: python embeddings.py build
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your_openai_key_here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_BATCH_SIZE=64

# Retrieval reranking
EVIDENCE_MESH_RERANK=1
EVIDENCE_MESH_RERANK_CANDIDATES=40
EVIDENCE_MESH_RERANK_MAX_TOKENS=1800

# Typed entity and claim extraction
EVIDENCE_MESH_ENTITY_CLAIM_MAX_TOKENS=1800

# Precomputed community/domain summaries
EVIDENCE_MESH_COMMUNITY_SUMMARY_MAX_TOKENS=2200
EVIDENCE_MESH_SUMMARY_MAX_CARDS=28

# Storage
# PostgreSQL is the primary storage. Use EVIDENCE_MESH_STORAGE=json only for local
# throwaway debugging.
EVIDENCE_MESH_STORAGE=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/evidence_mesh
POSTGRES_CONNECT_TIMEOUT=5
EVIDENCE_MESH_PROJECT_ID=local
